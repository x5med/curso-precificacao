# Supabase — usado pela Server Action em app/actions.js (somente servidor).
# Copie este arquivo para .env.local e preencha com os valores do seu projeto.
# Project Settings > API no painel do Supabase.

# URL do projeto (ex.: https://xxxxxxxx.supabase.co)
SUPABASE_URL=

# service_role key — SECRETA. Nunca exponha no cliente nem comite no git.
SUPABASE_SERVICE_ROLE_KEY=
